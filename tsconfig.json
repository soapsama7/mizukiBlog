{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"baseUrl": ".",
		"strictNullChecks": true,
		"allowJs": false,
		"declaration": true,
		"plugins": [
			{
				"name": "@astrojs/ts-plugin"
			}
		],
		"paths": {
			"@components/*": ["src/components/*"],
			"@utils/*": ["src/utils/*"],
			"@layouts/*": ["src/layouts/*"],
			"@/*": ["src/*"]
		}
	},
	"include": [
		"src/pages/**/*.astro",
		"src/layouts/AzaMOELayout.astro",
		"src/layouts/CornerLayout.astro",
		"src/components/misc/**/*.astro",
		"src/data/**/*.ts",
		"src/utils/album-scanner.ts",
		"src/scripts/handlers/**/*.ts",
		"src/types/**/*.ts",
		"src/config.ts",
		"src/content.config.ts",
		"src/global.d.ts"
	]
}
