---
import { musicPlayerConfig, siteConfig, themeTextConfig } from "../config";
import "../styles/azamoe-theme.css";
import "../styles/fancybox-custom.css";

interface Props {
	title?: string;
	current?: string;
}

const { title = "AzaMOE", current = "home" } = Astro.props;
const navItems = themeTextConfig.navItems;
const fullTitle = current === "home"
	? `${siteConfig.title} - ${themeTextConfig.pages.home.title}`
	: `${siteConfig.title} - ${title}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href={siteConfig.favicon} />
		<title>{fullTitle}</title>
	</head>
	<body class="corner-clone">
		<aside id="corner-nav" class={current === "home" ? "home" : ""}>
			<button id="corner-menu" aria-label="Menu">
				<span />
				<span />
				<span />
			</button>
			<div id="corner-items">
				{navItems.map((item) => (
					<>
						<a
							class:list={[
								"corner-link",
								{ "corner-link-home": item.key === "home" },
								{ active: current === item.key },
							]}
							data-nav-key={item.key}
							href={item.href}
							aria-label={item.label}
						>
							{item.key === "home" ? (
								<>
									<span class="corner-sr-only">{item.label}</span>
									<svg
										class="corner-home-icon"
										viewBox="0 0 24 24"
										aria-hidden="true"
										focusable="false"
									>
										<path d="M4 10.8 12 4l8 6.8" />
										<path d="M6.5 9.5v9h11v-9" />
										<path d="M10 18.5v-5h4v5" />
									</svg>
								</>
							) : (
								item.label
							)}
						</a>
						{item.key !== "home" && <div class="corner-dot">·</div>}
					</>
				))}
			</div>
			<div id="corner-bookmark" />
			<div id="corner-nav-background" />
		</aside>
		<button id="corner-theme-toggle" type="button" aria-label="切换黑夜模式">
			🌙
		</button>
		<main id="corner-main">
			<slot />
		</main>
		{musicPlayerConfig.enable && (
			<div
				id="aza-player"
				data-playlist={JSON.stringify(musicPlayerConfig.playlist)}
				data-mode={musicPlayerConfig.mode}
				data-autoplay={musicPlayerConfig.autoplay ? "true" : "false"}
				data-loop={musicPlayerConfig.loop || "all"}
				data-volume={String(musicPlayerConfig.defaultVolume ?? 0.65)}
				data-empty-title={musicPlayerConfig.emptyState?.title || "暂无可播放音乐"}
				data-empty-artist={musicPlayerConfig.emptyState?.artist || "请检查音乐配置"}
			>
				<button id="aza-player-toggle" type="button" aria-label="播放或暂停">▶</button>
				<div id="aza-player-meta">
					<div id="aza-player-title">
						{musicPlayerConfig.playlist[0]?.title || musicPlayerConfig.emptyState?.title || "暂无可播放音乐"}
					</div>
					<div id="aza-player-artist">
						{musicPlayerConfig.playlist[0]?.artist || musicPlayerConfig.emptyState?.artist || "请检查音乐配置"}
					</div>
				</div>
				<button id="aza-player-next" type="button" aria-label="下一首">»</button>
				<button id="aza-player-list-toggle" type="button" aria-label="展开歌单">≡</button>
				<div id="aza-player-progress-wrap">
					<input
						id="aza-player-progress"
						type="range"
						min="0"
						max="1000"
						step="1"
						value="0"
						aria-label="播放进度"
					/>
					<div id="aza-player-time">00:00 / 00:00</div>
				</div>
				<div id="aza-player-list-panel" class="collapsed">
					<ul id="aza-player-list" />
				</div>
				<audio
					id="aza-player-audio"
					preload="none"
					src={musicPlayerConfig.playlist[0]?.src || ""}
				/>
			</div>
		)}
	</body>
</html>

<script>
	import { initAboutAccordion } from "../scripts/handlers/about-accordion";
	import { initPostEnhancements } from "../scripts/handlers/post-enhancements";

	const CORNER_THEME_KEY = "corner-theme";

	function applyCornerTheme(theme: "light" | "dark") {
		const body = document.body;
		const toggle = document.getElementById("corner-theme-toggle");
		if (!body || !toggle) return;
		body.classList.toggle("dark-mode", theme === "dark");
		toggle.textContent = theme === "dark" ? "☀️" : "🌙";
		toggle.setAttribute(
			"aria-label",
			theme === "dark" ? "切换浅色模式" : "切换黑夜模式",
		);
	}

	function getPreferredCornerTheme(): "light" | "dark" {
		const saved = localStorage.getItem(CORNER_THEME_KEY);
		if (saved === "dark" || saved === "light") {
			return saved;
		}
		return window.matchMedia("(prefers-color-scheme: dark)").matches
			? "dark"
			: "light";
	}

	function setupCornerThemeToggle() {
		const toggle = document.getElementById("corner-theme-toggle");
		if (!toggle || toggle.dataset.bound === "true") return;
		toggle.dataset.bound = "true";

		applyCornerTheme(getPreferredCornerTheme());
		toggle.addEventListener("click", () => {
			const nextTheme = document.body.classList.contains("dark-mode")
				? "light"
				: "dark";
			localStorage.setItem(CORNER_THEME_KEY, nextTheme);
			applyCornerTheme(nextTheme);
		});
	}

	function updateCornerBookmark() {
		const nav = document.getElementById("corner-nav");
		const bookmark = document.getElementById("corner-bookmark");
		if (!nav || !bookmark) {
			return;
		}

		const active =
			nav.querySelector(".corner-link.active") || nav.querySelector(".corner-link");
		if (!(active instanceof HTMLElement)) {
			return;
		}

		const box = active.getBoundingClientRect();
		const navBox = nav.getBoundingClientRect();
		const h = box.height;
		const width = Math.round(h / 2) + 8;
		bookmark.style.top = `${box.top - navBox.top - 8}px`;
		bookmark.style.borderWidth = `${width}px 20px ${width}px 50px`;
		bookmark.style.opacity = "1";
	}

	function syncActiveNavByPath() {
		const links = Array.from(
			document.querySelectorAll<HTMLAnchorElement>("#corner-items .corner-link"),
		);
		if (links.length === 0) {
			return;
		}
		const path = window.location.pathname.replace(/\/+$/, "") || "/";
		let activeLink: HTMLAnchorElement | null = null;
		for (const link of links) {
			const linkPath = new URL(link.href, window.location.origin).pathname.replace(/\/+$/, "") || "/";
			const isRoot = linkPath === "/";
			const matched = isRoot ? path === "/" : path === linkPath || path.startsWith(`${linkPath}/`);
			link.classList.toggle("active", matched);
			if (matched) {
				activeLink = link;
			}
		}
		if (!activeLink) {
			links.forEach((l) => l.classList.remove("active"));
			links[0]?.classList.add("active");
		}
	}

	function setupCornerNavBookmarkFollow() {
		const links = Array.from(
			document.querySelectorAll<HTMLAnchorElement>("#corner-items .corner-link"),
		);
		links.forEach((link) => {
			link.addEventListener("click", () => {
				links.forEach((l) => l.classList.remove("active"));
				link.classList.add("active");
				updateCornerBookmark();
			});
		});
	}

	function setupMobileCornerNav() {
		const nav = document.getElementById("corner-nav");
		const toggle = document.getElementById("corner-menu");
		if (!nav || !toggle) {
			return;
		}
		toggle.addEventListener("click", () => {
			nav.classList.toggle("open");
			window.setTimeout(() => nav.classList.remove("open"), 2000);
		});
	}

	function setupAzaMusicPlayer() {
		const root = document.getElementById("aza-player");
		if (!root || root.dataset.bound === "true") return;
		root.dataset.bound = "true";

		const audio = document.getElementById("aza-player-audio") as HTMLAudioElement | null;
		const toggle = document.getElementById("aza-player-toggle") as HTMLButtonElement | null;
		const next = document.getElementById("aza-player-next") as HTMLButtonElement | null;
		const listToggle = document.getElementById("aza-player-list-toggle") as HTMLButtonElement | null;
		const titleEl = document.getElementById("aza-player-title");
		const artistEl = document.getElementById("aza-player-artist");
		const progress = document.getElementById("aza-player-progress") as HTMLInputElement | null;
		const timeEl = document.getElementById("aza-player-time");
		const listPanel = document.getElementById("aza-player-list-panel");
		const listEl = document.getElementById("aza-player-list");
		if (!audio || !toggle || !next || !listToggle || !titleEl || !artistEl || !progress || !timeEl || !listPanel || !listEl) return;

		const raw = root.getAttribute("data-playlist");
		if (!raw) return;
		const playlist = JSON.parse(raw) as Array<{ title: string; artist?: string; src: string }>;
		if (!Array.isArray(playlist)) return;
		const mode = root.getAttribute("data-mode") || "local";
		const autoplay = root.getAttribute("data-autoplay") === "true";
		const loopMode = root.getAttribute("data-loop") || "all";
		const initVolume = Number(root.getAttribute("data-volume") || "0.65");
		const emptyTitle = root.getAttribute("data-empty-title") || "暂无可播放音乐";
		const emptyArtist = root.getAttribute("data-empty-artist") || "请检查音乐配置";

		let idx = 0;
		let seeking = false;
		audio.volume = Number.isFinite(initVolume) ? Math.min(Math.max(initVolume, 0), 1) : 0.65;
		audio.loop = loopMode === "one";

		const formatTime = (s: number) => {
			if (!Number.isFinite(s) || s < 0) return "00:00";
			const sec = Math.floor(s);
			const m = Math.floor(sec / 60);
			const r = sec % 60;
			return `${String(m).padStart(2, "0")}:${String(r).padStart(2, "0")}`;
		};

		const updateProgress = () => {
			const duration = audio.duration;
			const current = audio.currentTime;
			if (!seeking) {
				if (Number.isFinite(duration) && duration > 0) {
					progress.value = String(Math.round((current / duration) * 1000));
				} else {
					progress.value = "0";
				}
			}
			timeEl.textContent = `${formatTime(current)} / ${formatTime(duration)}`;
		};

		const renderPlaylist = () => {
			listEl.innerHTML = "";
			playlist.forEach((track, i) => {
				const li = document.createElement("li");
				const btn = document.createElement("button");
				btn.type = "button";
				btn.className = i === idx ? "active" : "";
				btn.textContent = `${track.title}${track.artist ? ` - ${track.artist}` : ""}`;
				btn.addEventListener("click", () => loadTrack(i, true));
				li.appendChild(btn);
				listEl.appendChild(li);
			});
		};

		const syncMeta = () => {
			const currentTrack = playlist[idx];
			titleEl.textContent = currentTrack?.title || emptyTitle;
			artistEl.textContent = currentTrack?.artist || emptyArtist;
			toggle.textContent = audio.paused ? "▶" : "❚❚";
			renderPlaylist();
			updateProgress();
		};

		const loadTrack = (nextIdx: number, autoplay = false) => {
			if (playlist.length === 0) return;
			idx = (nextIdx + playlist.length) % playlist.length;
			audio.src = playlist[idx].src;
			syncMeta();
			if (autoplay) {
				audio.play().catch(() => {});
			}
		};

		toggle.addEventListener("click", () => {
			if (!audio.src && playlist.length > 0) {
				loadTrack(idx, false);
			}
			if (audio.paused) {
				audio.play().catch(() => {});
			} else {
				audio.pause();
			}
		});

		next.addEventListener("click", () => {
			if (playlist.length === 0) return;
			loadTrack(idx + 1, !audio.paused);
		});
		listToggle.addEventListener("click", () => {
			listPanel.classList.toggle("collapsed");
		});
		progress.addEventListener("pointerdown", () => {
			seeking = true;
		});
		progress.addEventListener("pointerup", () => {
			const duration = audio.duration;
			if (Number.isFinite(duration) && duration > 0) {
				audio.currentTime = (Number(progress.value) / 1000) * duration;
			}
			seeking = false;
			updateProgress();
		});
		progress.addEventListener("input", () => {
			const duration = audio.duration;
			if (Number.isFinite(duration) && duration > 0) {
				const preview = (Number(progress.value) / 1000) * duration;
				timeEl.textContent = `${formatTime(preview)} / ${formatTime(duration)}`;
			}
		});
		audio.addEventListener("play", syncMeta);
		audio.addEventListener("pause", syncMeta);
		audio.addEventListener("timeupdate", updateProgress);
		audio.addEventListener("loadedmetadata", updateProgress);
		audio.addEventListener("ended", () => {
			if (loopMode === "off") {
				toggle.textContent = "▶";
				return;
			}
			loadTrack(idx + 1, true);
		});

		// 非 local 模式（netease/meting）：从后端 API 拉歌单；失败时保持空播放器
		if (mode !== "local") {
			fetch("/api/music/playlist.json")
				.then((r) => (r.ok ? r.json() : Promise.reject(new Error("music api failed"))))
				.then((data) => {
					if (!Array.isArray(data?.playlist) || data.playlist.length === 0) return;
					playlist.splice(0, playlist.length, ...data.playlist);
					loadTrack(0, autoplay);
				})
				.catch(() => {});
		} else if (autoplay) {
			audio.play().catch(() => {});
		}
		syncMeta();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", syncActiveNavByPath);
		document.addEventListener("DOMContentLoaded", updateCornerBookmark);
		document.addEventListener("DOMContentLoaded", setupCornerNavBookmarkFollow);
		document.addEventListener("DOMContentLoaded", setupMobileCornerNav);
		document.addEventListener("DOMContentLoaded", setupCornerThemeToggle);
		document.addEventListener("DOMContentLoaded", setupAzaMusicPlayer);
		document.addEventListener("DOMContentLoaded", initAboutAccordion);
		document.addEventListener("DOMContentLoaded", initPostEnhancements);
	} else {
		syncActiveNavByPath();
		updateCornerBookmark();
		setupCornerNavBookmarkFollow();
		setupMobileCornerNav();
		setupCornerThemeToggle();
		setupAzaMusicPlayer();
		initAboutAccordion();
		initPostEnhancements();
	}
	document.addEventListener("astro:page-load", setupCornerThemeToggle);
	document.addEventListener("astro:page-load", setupAzaMusicPlayer);
	document.addEventListener("astro:page-load", initAboutAccordion);
	document.addEventListener("astro:page-load", initPostEnhancements);
	document.addEventListener("swup:pageView", initAboutAccordion);
	document.addEventListener("swup:pageView", initPostEnhancements);
	document.addEventListener("swup:page:view", initAboutAccordion);
	document.addEventListener("swup:page:view", initPostEnhancements);

	const swupForAbout = (window as Window & { swup?: { hooks?: { on?: (event: string, cb: () => void) => void } } }).swup;
	if (swupForAbout?.hooks?.on) {
		swupForAbout.hooks.on("page:view", initAboutAccordion);
		swupForAbout.hooks.on("page:view", initPostEnhancements);
	}
	window.addEventListener("resize", () => {
		syncActiveNavByPath();
		updateCornerBookmark();
	}, { passive: true });
	window.addEventListener("load", updateCornerBookmark);
	document.addEventListener("visibilitychange", () => {
		if (!document.hidden) {
			syncActiveNavByPath();
			updateCornerBookmark();
		}
	});
	window.setTimeout(() => {
		syncActiveNavByPath();
		updateCornerBookmark();
	}, 120);
	window.setTimeout(() => {
		syncActiveNavByPath();
		updateCornerBookmark();
	}, 360);
	window.setInterval(() => {
		syncActiveNavByPath();
		updateCornerBookmark();
	}, 1200);
</script>
