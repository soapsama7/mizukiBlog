---
import Markdown from "@components/misc/Markdown.astro";
import AzaMOELayout from "@layouts/AzaMOELayout.astro";
import { getEntry, render } from "astro:content";
import { themeTextConfig } from "../config";

import { getShuffledFriendsList } from "../data/friends";

const friendsPost = await getEntry("spec", "friends");

if (!friendsPost) {
	throw new Error("friends page content not found");
}

const { Content } = await render(friendsPost);
const friendsList = getShuffledFriendsList();
---

<AzaMOELayout current="friends" title={themeTextConfig.pages.friends.title}>
	<section class="corner-blog">
		<h2>{themeTextConfig.pages.friends.title}</h2>
		<div class="corner-subtitle">{themeTextConfig.pages.friends.subtitle}</div>
		<div class="corner-grid">
			{
				friendsList.map((item) => (
					<article class="corner-card corner-friend-card">
						<div class="corner-friend-header">
							<img class="corner-avatar-img" src={item.imgurl} alt={item.title} loading="lazy" />
							<div>
								<a class="corner-title" href={item.siteurl} target="_blank" rel="noreferrer">
									{item.title}
								</a>
							</div>
						</div>
						<div class="corner-excerpt">{item.desc}</div>
					</article>
				))
			}
		</div>
		<article class="corner-card corner-friends-apply" style="margin-top: 1rem;">
			<Markdown class="markdown-content">
				<Content />
			</Markdown>
		</article>
	</section>
</AzaMOELayout>
