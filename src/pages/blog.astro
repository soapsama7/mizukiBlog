---
import AzaMOELayout from "../layouts/AzaMOELayout.astro";
import { getCollection } from "astro:content";
import { themeTextConfig } from "../config";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
	(a, b) =>
		new Date(b.data.published).getTime() - new Date(a.data.published).getTime(),
);

const toSlug = (id: string) => id.replace(/\.[^/.]+$/, "");
---

<AzaMOELayout current="blog" title={themeTextConfig.pages.blog.title}>
	<section class="corner-blog">
		<div>
			<h2>{themeTextConfig.pages.blog.title}</h2>
			<div class="corner-subtitle">{themeTextConfig.pages.blog.subtitle}</div>
		</div>
		{
			posts.map((post) => (
				<article class="corner-card">
					<div class="corner-date">
						{new Date(post.data.published).toISOString().slice(0, 10)}
					</div>
					<a class="corner-title" href={`/blog/${toSlug(post.id)}/`}>
						{post.data.title}
					</a>
					{post.data.description && (
						<div class="corner-excerpt">{post.data.description}</div>
					)}
				</article>
			))
		}
	</section>
</AzaMOELayout>
