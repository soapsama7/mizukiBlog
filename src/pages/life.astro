---
import AzaMOELayout from "../layouts/AzaMOELayout.astro";
import { getDiaryList } from "../data/diary";
import { themeTextConfig } from "../config";

const diaryList = getDiaryList();
---

<AzaMOELayout current="life" title={themeTextConfig.pages.life.title}>
	<section class="corner-blog">
		<h2>{themeTextConfig.pages.life.title}</h2>
		<div class="corner-subtitle">{themeTextConfig.pages.life.subtitle}</div>
		{
			diaryList.length === 0 ? (
				<article class="corner-card">还没有内容</article>
			) : (
				diaryList.map((item) => (
					<article class="corner-card">
						<div class="corner-date">{new Date(item.date).toISOString().slice(0, 10)}</div>
						<div class="corner-excerpt">{item.content}</div>
					</article>
				))
			)
		}
	</section>
</AzaMOELayout>
