---
import CornerLayout from "../layouts/CornerLayout.astro";
import { scanAlbums } from "../utils/album-scanner";

// 获取所有相册
const albumsData = await scanAlbums();
---

<CornerLayout current="albums" title="相册">
	<section class="corner-blog">
		<h2>相册</h2>
		<div class="corner-subtitle">收藏生活里的片段</div>
		<div class="corner-grid">
			{
				albumsData.map((album) => (
					<article class="corner-card">
						<a href={`/albums/${album.id}/`}>
							<img class="corner-album-cover" src={album.cover} alt={album.title} loading="lazy" />
						</a>
						<a class="corner-title" href={`/albums/${album.id}/`}>
							{album.title}
						</a>
						<div class="corner-excerpt">{album.description || "暂无描述"}</div>
					</article>
				))
			}
		</div>
	</section>
</CornerLayout>