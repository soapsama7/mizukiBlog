		<article class="corner-card" style="text-align:center; padding: 2.5rem 1rem;">
			<div class="corner-title" style="font-size: 2rem; margin-bottom: 0.75rem;">404</div>
			<div class="corner-subtitle" style="margin-bottom: 1.2rem;">页面不存在或已被移动</div>
			<a class="corner-title" href="/" style="display:inline-block;">返回主页</a>
		</article>
	</section>
</AzaMOELayout>